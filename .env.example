# ATI Academy LMS — copy to .env and fill in.
NODE_ENV=development
PORT=8080

# SQLite for dev. For production, point this at a Postgres URL and swap the
# Drizzle driver in server/db.ts.
DATABASE_URL=./data/lms.db

# Long random string — signs session cookies. CHANGE THIS.
SESSION_SECRET=dev-only-change-me

# Seeded admin account (created by db:seed if it doesn't exist yet).
SEED_ADMIN_EMAIL=admin@atiacademy.test
SEED_ADMIN_PASSWORD=changeme123
